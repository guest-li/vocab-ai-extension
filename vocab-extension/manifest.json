{
  "manifest_version": 3,
  "name": "English Vocabulary Tool",
  "version": "2.0",
  "description": "Learn English vocabulary efficiently with offline word lookup and quiz mode",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Vocab Tool",
    "default_popup": "popup.html",
    "default_icons": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "permissions": [],
  "host_permissions": [
    "https://api.dictionaryapi.dev/*",
    "https://translate.googleapis.com/*"
  ]
}
